# ============================================================
# ~/.claude/.gitignore — synchronisation entre postes
# ============================================================
# Stratégie: tout ignorer par défaut, puis whitelister explicitement
# ce qui est portable (config + mémoires).
# ============================================================

# --- 1. Tout ignorer par défaut ---
/*

# --- 2. Whitelist racine ---
!/.gitignore
!/CLAUDE.md
!/README.md
!/RTK.md
!/settings.json
!/sync.sh

# --- 3. Whitelist projects/<projet>/memory/*.md uniquement ---
# (le reste de projects/<projet>/ — transcripts, sous-agents, tool-results — reste ignoré)
!/projects/
projects/*
!projects/*/
projects/*/*
!projects/*/memory/
projects/*/memory/*
!projects/*/memory/*.md

# --- 4. Garde-fou paranoïa sur les secrets ---
# (redondant avec section 1 aujourd'hui, mais survit à un éventuel
#  élargissement futur de la whitelist racine)
.credentials.json
.env
.env.*
*.pem
*.key
